BOOTSTRAP: docker
FROM: debian:13

%files
matplot3.py /usr/local/bin/plot3
draggable_text.py /opt/draggable_text.py
ROC.py /opt/ROC.py

%post
apt-get update
apt-get install -y python3-tk
apt-get install -y python3-pip
pip3 install --break-system-packages scikit-learn
pip3 install --break-system-packages scipy
pip3 install --break-system-packages numexpr
pip3 install --break-system-packages numpy
pip3 install --break-system-packages pillow
pip3 install --break-system-packages matplotlib
pip3 install --break-system-packages typer
pip3 install --break-system-packages rich
chmod +x /usr/local/bin/plot3

# Dynamically find the site-packages or dist-packages directory
PDIR=$(python3 -c "import site; print([p for p in site.getsitepackages() if 'dist-packages' in p][0])")
mv /opt/draggable_text.py $PDIR/
mv /opt/ROC.py $PDIR/

%runscript
exec /usr/local/bin/plot3 "$@"

%help
This is an Apptainer container for matplot3.py.
Use it by running:
  ./matplot3.sif [options]
The command is aliased to 'plot3'.
